# Ejemplo de archivo .env
# Crea una copia llamada .env y completa con tus credenciales

# Credenciales para el Banco Falabella
FALABELLA_USER=tu_usuario
FALABELLA_PASSWORD=tu_contraseña

# Base de datos Supabase
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres